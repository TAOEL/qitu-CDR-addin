<UserControl x:Class="QiTuCDR.AddonEntry"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             MinHeight="40"
             MaxHeight="40"
             Background="#F8F9FA">

    <UserControl.Resources>
        <!-- ═══ QiTuCDR v2.0 · 浅色柔和主题 · 自包含资源 ═══ -->

        <!-- 品牌色 -->
        <SolidColorBrush x:Key="BrandPrimaryBrush" Color="#81C784" />
        <SolidColorBrush x:Key="BrandLightBrush" Color="#E8F5E9" />

        <!-- 背景/边框 -->
        <SolidColorBrush x:Key="BgSecondaryBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#E8ECEF" />

        <!-- 文字 -->
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#2D3436" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#636E72" />
        <SolidColorBrush x:Key="TextTertiaryBrush" Color="#B2BEC3" />
        <SolidColorBrush x:Key="TextInverseBrush" Color="#FFFFFF" />

        <!-- 工具栏 -->
        <SolidColorBrush x:Key="ToolbarHoverBrush" Color="#E8ECEF" />

        <!-- 阴影 -->
        <Color x:Key="ShadowColor">#33000000</Color>

        <!-- ═══ 样式 ═══ -->

        <!-- 工具栏按钮 -->
        <Style x:Key="ToolbarButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI, sans-serif" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="2,3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center" />
                                <TextBlock Text="▼" FontSize="9"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0" />
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ToolbarHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrandLightBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BrandPrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 下拉菜单项 -->
        <Style x:Key="PopupMenuItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI, sans-serif" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F5E9" />
                    <Setter Property="Foreground" Value="#2E7D32" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 菜单分隔线 -->
        <Style x:Key="MenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{StaticResource BorderBrush}" />
            <Setter Property="Margin" Value="10,3" />
        </Style>

        <!-- 下拉面板容器 -->
        <Style x:Key="PopupPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="#F8F9FA"
                BorderBrush="#E8ECEF"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 品牌标识：企图插件 -->
                <ToggleButton Grid.Column="0" x:Name="BtnBrand"
                              Style="{StaticResource ToolbarButtonStyle}"
                              Content="企图插件"
                              IsChecked="{Binding IsBrandOpen}"
                              Click="ToggleCategory_Click" Tag="Brand" />
                <Popup IsOpen="{Binding IsBrandOpen}" StaysOpen="False"
                       PlacementTarget="{Binding ElementName=BtnBrand}"
                       Placement="Bottom">
                    <Border Style="{StaticResource PopupPanelStyle}" MinWidth="140">
                        <StackPanel>
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="功能市场" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="同步数据" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="功能管理" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="个人中心" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="系统设置" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="关于插件" Click="OnFeatureMenu_Click" />
                        </StackPanel>
                    </Border>
                </Popup>

                <Separator Grid.Column="0" Width="1" Style="{StaticResource MenuSeparatorStyle}"
                           HorizontalAlignment="Right" VerticalAlignment="Stretch" Margin="0,4" />

                <!-- 工具面板 -->
                <ToggleButton Grid.Column="1" x:Name="BtnHome"
                              Style="{StaticResource ToolbarButtonStyle}"
                              Content="工具面板"
                              IsChecked="{Binding IsHomeOpen}"
                              Click="ToggleCategory_Click" Tag="Home" />
                <Popup IsOpen="{Binding IsHomeOpen}" StaysOpen="False"
                       PlacementTarget="{Binding ElementName=BtnHome}"
                       Placement="Bottom">
                    <Border Style="{StaticResource PopupPanelStyle}" MinWidth="180">
                        <StackPanel>
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="批量对齐" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="等间距分布" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="尺寸统一" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="批量替换" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="批量导出" Click="OnFeatureMenu_Click" />
                        </StackPanel>
                    </Border>
                </Popup>

                <Separator Grid.Column="2" Width="1" Style="{StaticResource MenuSeparatorStyle}" />

                <!-- 排版工具 -->
                <ToggleButton Grid.Column="2" x:Name="BtnLayout"
                              Style="{StaticResource ToolbarButtonStyle}"
                              Content="排版工具"
                              IsChecked="{Binding IsLayoutOpen}"
                              Click="ToggleCategory_Click" Tag="Layout" />
                <Popup IsOpen="{Binding IsLayoutOpen}" StaysOpen="False"
                       PlacementTarget="{Binding ElementName=BtnLayout}"
                       Placement="Bottom">
                    <Border Style="{StaticResource PopupPanelStyle}" MinWidth="150">
                        <StackPanel>
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="批量对齐" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="等间距分布" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="尺寸统一" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="群组管理" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="图层批量操作" Click="OnFeatureMenu_Click" />
                        </StackPanel>
                    </Border>
                </Popup>

                <Separator Grid.Column="3" Width="1" Style="{StaticResource MenuSeparatorStyle}" />

                <!-- 图形工具 -->
                <ToggleButton Grid.Column="3" x:Name="BtnGraphics"
                              Style="{StaticResource ToolbarButtonStyle}"
                              Content="图形工具"
                              IsChecked="{Binding IsGraphicsOpen}"
                              Click="ToggleCategory_Click" Tag="Graphics" />
                <Popup IsOpen="{Binding IsGraphicsOpen}" StaysOpen="False"
                       PlacementTarget="{Binding ElementName=BtnGraphics}"
                       Placement="Bottom">
                    <Border Style="{StaticResource PopupPanelStyle}" MinWidth="150">
                        <StackPanel>
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="批量替换" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="批量导出" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="智能裁切" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="圆角生成" Click="OnFeatureMenu_Click" />
                        </StackPanel>
                    </Border>
                </Popup>

                <Separator Grid.Column="4" Width="1" Style="{StaticResource MenuSeparatorStyle}" />

                <!-- 文字工具 -->
                <ToggleButton Grid.Column="4" x:Name="BtnText"
                              Style="{StaticResource ToolbarButtonStyle}"
                              Content="文字工具"
                              IsChecked="{Binding IsTextOpen}"
                              Click="ToggleCategory_Click" Tag="Text" />
                <Popup IsOpen="{Binding IsTextOpen}" StaysOpen="False"
                       PlacementTarget="{Binding ElementName=BtnText}"
                       Placement="Bottom">
                    <Border Style="{StaticResource PopupPanelStyle}" MinWidth="150">
                        <StackPanel>
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="字体批量替换" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="文字转曲"
                                    Click="OnTextToCurves_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="文字统计" Click="OnFeatureMenu_Click" />
                        </StackPanel>
                    </Border>
                </Popup>

                <Separator Grid.Column="5" Width="1" Style="{StaticResource MenuSeparatorStyle}" />

                <!-- 颜色工具 -->
                <ToggleButton Grid.Column="5" x:Name="BtnColor"
                              Style="{StaticResource ToolbarButtonStyle}"
                              Content="颜色工具"
                              IsChecked="{Binding IsColorOpen}"
                              Click="ToggleCategory_Click" Tag="Color" />
                <Popup IsOpen="{Binding IsColorOpen}" StaysOpen="False"
                       PlacementTarget="{Binding ElementName=BtnColor}"
                       Placement="Bottom">
                    <Border Style="{StaticResource PopupPanelStyle}" MinWidth="150">
                        <StackPanel>
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="色板管理" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="颜色批量替换" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="色彩分析" Click="OnFeatureMenu_Click" />
                        </StackPanel>
                    </Border>
                </Popup>

                <Separator Grid.Column="6" Width="1" Style="{StaticResource MenuSeparatorStyle}" />

                <!-- AI 助手 -->
                <ToggleButton Grid.Column="6" x:Name="BtnAI"
                              Style="{StaticResource ToolbarButtonStyle}"
                              Content="AI 助手"
                              IsChecked="{Binding IsAIOpen}"
                              Click="ToggleCategory_Click" Tag="AI" />
                <Popup IsOpen="{Binding IsAIOpen}" StaysOpen="False"
                       PlacementTarget="{Binding ElementName=BtnAI}"
                       Placement="Bottom">
                    <Border Style="{StaticResource PopupPanelStyle}" MinWidth="180">
                        <StackPanel>
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="AI 文案改写" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="AI 排版建议" Click="OnFeatureMenu_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <Button Style="{StaticResource PopupMenuItemStyle}" Content="AI 色彩推荐" Click="OnFeatureMenu_Click" />
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- 用户状态 -->
                <Border Grid.Column="7" HorizontalAlignment="Right" Margin="8,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="24" Height="24" Fill="#3A3A55"
                                 VerticalAlignment="Center" Margin="8,0,0,0" />
                        <TextBlock Text="未登录" FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif"
                                   FontSize="11" Foreground="#B2BEC3"
                                   VerticalAlignment="Center" Margin="4,0,6,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
