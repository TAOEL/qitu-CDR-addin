<Window x:Class="QiTuCDR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="企图插件 QiTuCDR"
        Width="320" Height="600"
        MinWidth="280" MinHeight="400"
        WindowStyle="ToolWindow"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimaryBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 左侧导航栏 -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBgBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Height="56"
                        Background="{StaticResource SidebarHeaderBgBrush}"
                        BorderBrush="{StaticResource BrandPrimaryBrush}"
                        BorderThickness="0,0,0,2">
                    <TextBlock Text="QiTuCDR"
                               Foreground="{StaticResource TextInverseBrush}"
                               FontFamily="{StaticResource PrimaryFont}"
                               FontSize="{StaticResource FontSizeLg}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Border>

                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <Button Style="{StaticResource NavButtonStyle}" Content="工具面板"
                            Command="{Binding NavigateCommand}" CommandParameter="Home" />
                    <Button Style="{StaticResource NavButtonStyle}" Content="排版工具"
                            Command="{Binding NavigateCommand}" CommandParameter="Layout" />
                    <Button Style="{StaticResource NavButtonStyle}" Content="图形工具"
                            Command="{Binding NavigateCommand}" CommandParameter="Graphics" />
                    <Button Style="{StaticResource NavButtonStyle}" Content="文字工具"
                            Command="{Binding NavigateCommand}" CommandParameter="Text" />
                    <Button Style="{StaticResource NavButtonStyle}" Content="颜色工具"
                            Command="{Binding NavigateCommand}" CommandParameter="Color" />
                    <Button Style="{StaticResource NavButtonStyle}" Content="AI 助手"
                            Command="{Binding NavigateCommand}" CommandParameter="AI" />
                    <Button Style="{StaticResource NavButtonStyle}" Content="设置"
                            Command="{Binding NavigateCommand}" CommandParameter="Settings" />
                </StackPanel>

                <Border Grid.Row="2" Height="48" Background="{StaticResource SidebarHeaderBgBrush}" Padding="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="28" Height="28" Fill="{StaticResource SidebarAvatarBrush}" />
                        <TextBlock Text="未登录" Foreground="{StaticResource SidebarTextBrush}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 右侧内容区域 -->
        <Border Grid.Column="1" Background="{StaticResource BgSecondaryBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ContentControl Grid.Row="0" Content="{Binding CurrentView}" />

                <Border Grid.Row="1"
                        Height="{StaticResource StatusBarHeight}"
                        Background="{StaticResource BgPrimaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource StatusBarTextStyle}" Text="CDR V26" />
                        <TextBlock Text=" | "
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource BorderBrush}" />
                        <TextBlock Style="{StaticResource StatusBarTextStyle}"
                                   Text="{Binding StatusText}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
