<UserControl x:Class="QiTuCDR.Views.TextToCurvesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/QiTuCDR;component/Resources/DesignSystem.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="BgDark" Color="#2b2b2b" />
            <SolidColorBrush x:Key="BgWhite" Color="#ffffff" />
            <SolidColorBrush x:Key="BgTitlebar" Color="#f2f2f2" />
            <SolidColorBrush x:Key="BgBody" Color="#f8f9fa" />
            <SolidColorBrush x:Key="BorderLine" Color="#c9c9c9" />
            <SolidColorBrush x:Key="BorderThin" Color="#dddddd" />
            <SolidColorBrush x:Key="BorderDetect" Color="#e2e2e2" />
            <SolidColorBrush x:Key="TextMain" Color="#333333" />
            <SolidColorBrush x:Key="TextSub" Color="#444444" />
            <SolidColorBrush x:Key="TextMuted" Color="#555555" />
            <SolidColorBrush x:Key="AccentBlue" Color="#2196F3" />
            <SolidColorBrush x:Key="BtnDefault" Color="#eeeeee" />
            <SolidColorBrush x:Key="BtnDefaultText" Color="#333333" />
            <SolidColorBrush x:Key="BtnHover" Color="#e5e5e5" />
            <SolidColorBrush x:Key="BtnCloseHover" Color="#e81123" />
            <SolidColorBrush x:Key="TagBg" Color="#dddddd" />

            <!-- ComboBox 样式：自定义 Popup 无透明 + 浅淡边框，消除系统厚重阴影 -->
            <Style TargetType="ComboBox">
                <Setter Property="Foreground" Value="#333333" />
                <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="BorderBrush" Value="#dddddd" />
                <Setter Property="Background" Value="#f2f2f2" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton"
                                              Background="{TemplateBinding Background}"
                                              BorderBrush="{TemplateBinding BorderBrush}"
                                              BorderThickness="{TemplateBinding BorderThickness}"
                                              Foreground="{TemplateBinding Foreground}"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="3"
                                                    Padding="0,0,0,0">
                                                <Path x:Name="Arrow"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"
                                                      Data="M0,0 L4,4 L8,0"
                                                      Stroke="#666666"
                                                      StrokeThickness="1.5"
                                                      Fill="Transparent" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#999999" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="ContentSite"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  Margin="8,3,23,3"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left" />
                                <Popup x:Name="Popup"
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide">
                                    <Grid x:Name="DropDown"
                                          SnapsToDevicePixels="True"
                                          MinWidth="{TemplateBinding ActualWidth}"
                                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <Border x:Name="DropDownBorder"
                                                Background="White"
                                                BorderBrush="#c9c9c9"
                                                BorderThickness="1"
                                                CornerRadius="3" />
                                        <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Grid>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Border Style="{StaticResource WindowContainerStyle}">
            <Grid ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="ContentRow" Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="TitleBar"
                        Grid.Row="0"
                        Style="{StaticResource TitlebarStyle}"
                        MouseLeftButtonDown="OnTitleBarMouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="16" Height="16"
                                    Background="#333333"
                                    CornerRadius="2"
                                    VerticalAlignment="Center">
                                <TextBlock Text="C"
                                           Foreground="#ffffff"
                                           FontSize="12"
                                           FontFamily="Microsoft YaHei UI"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="智能转曲"
                                       Foreground="#333333"
                                       FontFamily="Microsoft YaHei UI"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0" />
                            <TextBlock x:Name="TxtVersion"
                                       Text="V1.0"
                                       Style="{StaticResource TitlebarVersionStyle}"
                                       Background="Transparent"
                                       Cursor="Hand"
                                       Margin="8,0,0,0"
                                       MouseLeftButtonDown="OnVersion_Click" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="BtnPin"
                                    Style="{StaticResource TitleBtn}"
                                    Click="OnPin_Click">
                                <Path x:Name="PinIcon"
                                      Data="M32 4H16L20 7L16 20C16 20 10 24 10 28H20L24 44L28 28H38C38 24 34 21.1667 32 20L28 7L32 4Z"
                                      Stroke="#333333"
                                      StrokeThickness="1"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="#333333"
                                      Width="10" Height="10"
                                      Stretch="Uniform" />
                            </Button>
                            <Button Style="{StaticResource TitleBtn}"
                                    Click="OnSettings_Click">
                                <Path Width="10" Height="10"
                                      Stretch="Uniform"
                                      Stroke="#333333"
                                      StrokeThickness="1"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent">
                                    <Path.Data>
                                        <GeometryGroup>
                                            <PathGeometry Figures="M24 4L18 10H10V18L4 24L10 30V38H18L24 44L30 38H38V30L44 24L38 18V10H30L24 4Z" />
                                            <PathGeometry Figures="M24 30C27.3137 30 30 27.3137 30 24C30 20.6863 27.3137 18 24 18C20.6863 18 18 20.6863 18 24C18 27.3137 20.6863 30 24 30Z" />
                                        </GeometryGroup>
                                    </Path.Data>
                                </Path>
                            </Button>
                            <Button x:Name="BtnCollapse"
                                    Style="{StaticResource TitleBtn}"
                                    Click="OnCollapse_Click">
                                <Path x:Name="CollapseIcon"
                                      Width="10" Height="10"
                                      Stretch="Uniform"
                                      Stroke="#333333"
                                      StrokeThickness="1"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent">
                                    <Path.Data>
                                        <GeometryGroup>
                                            <PathGeometry Figures="M22 42H6V26" />
                                            <PathGeometry Figures="M26 6H42V22" />
                                        </GeometryGroup>
                                    </Path.Data>
                                </Path>
                            </Button>
                            <Button Style="{StaticResource CloseBtn}"
                                    Click="OnClose_Click">
                                <Path Width="8" Height="8"
                                      Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent">
                                    <Path.Data>
                                        <GeometryGroup>
                                            <PathGeometry Figures="M8 8L40 40" />
                                            <PathGeometry Figures="M8 40L40 8" />
                                        </GeometryGroup>
                                    </Path.Data>
                                </Path>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer x:Name="ContentScrollViewer"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Background="#f8f9fa">
                    <StackPanel x:Name="ContentPanel"
                                Margin="20">

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="处理范围："
                                       Grid.Column="0"
                                       FontFamily="Microsoft YaHei UI"
                                       FontSize="13"
                                       Foreground="#444444"
                                       VerticalAlignment="Center" />
                            <ComboBox x:Name="ScopeCombo"
                                      Grid.Column="1"
                                      FontFamily="Microsoft YaHei UI"
                                      FontSize="13"
                                      Padding="6,4"
                                      BorderBrush="#dddddd"
                                      Background="#f2f2f2"
                                      SelectedIndex="1"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      SelectionChanged="OnScopeChanged">
                                <ComboBox.Resources>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
                                        <Setter Property="FontSize" Value="13" />
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBoxItem Content="仅选中" />
                                <ComboBoxItem Content="当前页面" />
                                <ComboBoxItem Content="整个文档" />
                            </ComboBox>
                        </Grid>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,12,0,0">
                            <TextBlock Text="对象类型："
                                       Width="100"
                                       FontFamily="Microsoft YaHei UI"
                                       FontSize="13"
                                       Foreground="#444444"
                                       VerticalAlignment="Center" />
                            <CheckBox x:Name="ChkConvertText"
                                      Content="文本"
                                      IsChecked="{Binding ConvertText, Mode=TwoWay}"
                                      FontFamily="Microsoft YaHei UI"
                                      FontSize="13"
                                      Foreground="#444444"
                                      Margin="0,0,20,0"
                                      Cursor="Hand" />
                            <CheckBox x:Name="ChkConvertGraphics"
                                      Content="图形"
                                      IsChecked="{Binding ConvertGraphics, Mode=TwoWay}"
                                      FontFamily="Microsoft YaHei UI"
                                      FontSize="13"
                                      Foreground="#444444"
                                      Margin="0,0,20,0"
                                      Cursor="Hand" />
                            <CheckBox x:Name="ChkConvertOutlines"
                                      Content="轮廓"
                                      IsChecked="{Binding ConvertOutlines, Mode=TwoWay}"
                                      FontFamily="Microsoft YaHei UI"
                                      FontSize="13"
                                      Foreground="#444444"
                                      Cursor="Hand" />
                        </StackPanel>

                        <Border Background="#ffffff"
                                BorderBrush="#e2e2e2"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock Text="智能检测结果"
                                           FontFamily="Microsoft YaHei UI"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="#333333"
                                           Margin="0,0,0,6" />
                                <Grid Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="文本对象："
                                               Grid.Column="0"
                                               FontFamily="Microsoft YaHei UI"
                                               FontSize="13"
                                               Foreground="#444444" />
                                    <TextBlock Text="{Binding TextCountInfo}"
                                               Grid.Column="1"
                                               FontFamily="Microsoft YaHei UI"
                                               FontSize="13"
                                               Foreground="#333333"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="图形对象："
                                               Grid.Column="0"
                                               FontFamily="Microsoft YaHei UI"
                                               FontSize="13"
                                               Foreground="#444444" />
                                    <TextBlock Text="{Binding GraphicsCountInfo}"
                                               Grid.Column="1"
                                               FontFamily="Microsoft YaHei UI"
                                               FontSize="13"
                                               Foreground="#333333"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <Grid Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="轮廓对象："
                                               Grid.Column="0"
                                               FontFamily="Microsoft YaHei UI"
                                               FontSize="13"
                                               Foreground="#444444" />
                                    <TextBlock Text="{Binding OutlineCountInfo}"
                                               Grid.Column="1"
                                               FontFamily="Microsoft YaHei UI"
                                               FontSize="13"
                                               Foreground="#333333"
                                               HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,14,0,0">
                            <Button Command="{Binding ExecuteCommand}"
                                    Height="32"
                                    MinWidth="120"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#2196F3"
                                                CornerRadius="6"
                                                x:Name="btnBg">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Margin="18,0,18,0" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="btnBg" Property="Background" Value="#1976D2" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="一键转曲"
                                           FontFamily="Microsoft YaHei UI"
                                           FontSize="13"
                                           Foreground="#ffffff" />
                            </Button>
                            <Button x:Name="BtnReset"
                                    Height="32"
                                    MinWidth="80"
                                    Margin="10,0,0,0"
                                    Cursor="Hand"
                                    Click="OnReset_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#eeeeee"
                                                CornerRadius="6"
                                                x:Name="bg">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Margin="14,0,14,0" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#e0e0e0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="重置"
                                           FontFamily="Microsoft YaHei UI"
                                           FontSize="13"
                                           Foreground="#333333" />
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
