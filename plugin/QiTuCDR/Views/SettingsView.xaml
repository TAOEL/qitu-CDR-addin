<UserControl x:Class="QiTuCDR.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/QiTuCDR;component/Resources/DesignSystem.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource PageContainerStyle}">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PageTitlebarStyle}">
                <TextBlock Text="设置"
                           Style="{StaticResource TitlebarTitleStyle}"
                           VerticalAlignment="Center" />
            </Border>

            <Border Grid.Row="1" Style="{StaticResource PageContentStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitleStyle}" Text="设置" Margin="0,0,0,12" />
                    <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="插件设置：通用选项、快捷键配置、云同步、关于信息。" Margin="0,0,0,16" />
                    <TextBlock Style="{StaticResource PlaceholderTextStyle}" Text="功能开发中..." />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
