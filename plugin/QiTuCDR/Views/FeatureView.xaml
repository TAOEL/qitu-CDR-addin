<UserControl x:Class="QiTuCDR.Views.FeatureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/QiTuCDR;component/Resources/DesignSystem.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Border Style="{StaticResource WindowContainerStyle}">
            <Grid ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="ContentRow" Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="TitleBar"
                        Grid.Row="0"
                        Style="{StaticResource TitlebarStyle}"
                        MouseLeftButtonDown="OnTitleBarMouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="16" Height="16"
                                    Background="#333333"
                                    CornerRadius="2"
                                    VerticalAlignment="Center">
                                <TextBlock Text="C"
                                           Foreground="#ffffff"
                                           FontSize="12"
                                           FontFamily="Microsoft YaHei UI"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock x:Name="FeatureTitleBlock"
                                       Style="{StaticResource TitlebarTitleStyle}"
                                       Margin="6,0,0,0" />
                            <TextBlock x:Name="TxtVersion"
                                       Text="V1.0"
                                       Style="{StaticResource TitlebarVersionStyle}"
                                       Background="Transparent"
                                       Cursor="Hand"
                                       Margin="8,0,0,0"
                                       MouseLeftButtonDown="OnVersion_Click" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="BtnPin"
                                    Style="{StaticResource TitleBtn}"
                                    Click="OnPin_Click">
                                <Path x:Name="PinIcon"
                                      Data="M32 4H16L20 7L16 20C16 20 10 24 10 28H20L24 44L28 28H38C38 24 34 21.1667 32 20L28 7L32 4Z"
                                      Stroke="#333333"
                                      StrokeThickness="1"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="#333333"
                                      Width="10" Height="10"
                                      Stretch="Uniform" />
                            </Button>
                            <Button Style="{StaticResource TitleBtn}"
                                    Click="OnSettings_Click">
                                <Path Width="10" Height="10"
                                      Stretch="Uniform"
                                      Stroke="#333333"
                                      StrokeThickness="1"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent">
                                    <Path.Data>
                                        <GeometryGroup>
                                            <PathGeometry Figures="M24 4L18 10H10V18L4 24L10 30V38H18L24 44L30 38H38V30L44 24L38 18V10H30L24 4Z" />
                                            <PathGeometry Figures="M24 30C27.3137 30 30 27.3137 30 24C30 20.6863 27.3137 18 24 18C20.6863 18 18 20.6863 18 24C18 27.3137 20.6863 30 24 30Z" />
                                        </GeometryGroup>
                                    </Path.Data>
                                </Path>
                            </Button>
                            <Button x:Name="BtnCollapse"
                                    Style="{StaticResource TitleBtn}"
                                    Click="OnCollapse_Click">
                                <Path x:Name="CollapseIcon"
                                      Width="10" Height="10"
                                      Stretch="Uniform"
                                      Stroke="#333333"
                                      StrokeThickness="1"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent">
                                    <Path.Data>
                                        <GeometryGroup>
                                            <PathGeometry Figures="M22 42H6V26" />
                                            <PathGeometry Figures="M26 6H42V22" />
                                        </GeometryGroup>
                                    </Path.Data>
                                </Path>
                            </Button>
                            <Button Style="{StaticResource CloseBtn}"
                                    Click="OnClose_Click">
                                <Path Width="8" Height="8"
                                      Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent">
                                    <Path.Data>
                                        <GeometryGroup>
                                            <PathGeometry Figures="M8 8L40 40" />
                                            <PathGeometry Figures="M8 40L40 8" />
                                        </GeometryGroup>
                                    </Path.Data>
                                </Path>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer x:Name="ContentScrollViewer"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource ContentAreaBrush}">
                    <StackPanel Margin="20">
                        <TextBlock x:Name="ContentTitleBlock"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"
                                   FontFamily="Microsoft YaHei UI"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="该功能正在开发中，敬请期待..."
                                   FontSize="13"
                                   Foreground="#666666"
                                   FontFamily="Microsoft YaHei UI"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
