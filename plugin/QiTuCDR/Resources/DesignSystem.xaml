<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║           QiTuCDR Design System v2.0                        ║
    ║           浅色主题 · 清新柔和 · 现代简约                       ║
    ╚══════════════════════════════════════════════════════════════╝

    设计原则：
      1. 浅色柔和调性：背景 #F8F9FA，卡片纯白，深色点缀 #1A1A2E
      2. 三色语义系统：绿 #81C784（成功/主色）· 蓝 #64B5F6（信息）· 橙 #FFB74D（警告）
      3. 所有 XAML 通过 StaticResource 引用此处定义，消除硬编码
    -->

    <!-- ════════════════════════════════════════════════════════
         一、色彩系统
         ═════════════════════════════════════════════════════════ -->

    <!-- ── 主色调 · 语义三色 ── -->
    <Color x:Key="AccentGreenColor">#81C784</Color>
    <Color x:Key="AccentBlueColor">#64B5F6</Color>
    <Color x:Key="AccentOrangeColor">#FFB74D</Color>
    <Color x:Key="AccentRedColor">#EF5350</Color>

    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreenColor}" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlueColor}" />
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrangeColor}" />
    <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRedColor}" />

    <!-- ── 品牌色（基于绿色强调） ── -->
    <Color x:Key="BrandPrimaryColor">#81C784</Color>
    <Color x:Key="BrandHoverColor">#66BB6A</Color>
    <Color x:Key="BrandLightColor">#E8F5E9</Color>
    <Color x:Key="BrandDarkColor">#1A1A2E</Color>

    <SolidColorBrush x:Key="BrandPrimaryBrush" Color="{StaticResource BrandPrimaryColor}" />
    <SolidColorBrush x:Key="BrandHoverBrush" Color="{StaticResource BrandHoverColor}" />
    <SolidColorBrush x:Key="BrandLightBrush" Color="{StaticResource BrandLightColor}" />
    <SolidColorBrush x:Key="BrandDarkBrush" Color="{StaticResource BrandDarkColor}" />

    <!-- ── 背景色 ── -->
    <Color x:Key="BgPrimaryColor">#F8F9FA</Color>
    <Color x:Key="BgSecondaryColor">#FFFFFF</Color>
    <Color x:Key="BgCardColor">#FFFFFF</Color>

    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimaryColor}" />
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondaryColor}" />
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCardColor}" />

    <!-- ── 文字色 ── -->
    <Color x:Key="TextPrimaryColor">#2D3436</Color>
    <Color x:Key="TextSecondaryColor">#636E72</Color>
    <Color x:Key="TextTertiaryColor">#B2BEC3</Color>
    <Color x:Key="TextInverseColor">#FFFFFF</Color>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="{StaticResource TextInverseColor}" />

    <!-- ── 语义色 ── -->
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FF9800</Color>
    <Color x:Key="ErrorColor">#EF5350</Color>
    <Color x:Key="InfoColor">#2196F3</Color>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />

    <!-- ── 边框与分隔 ── -->
    <Color x:Key="BorderColor">#E8ECEF</Color>
    <Color x:Key="BorderDarkColor">#2D2D44</Color>
    <Color x:Key="DividerColor">#E8ECEF</Color>

    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderDarkBrush" Color="{StaticResource BorderDarkColor}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}" />

    <!-- ── 工具栏专用 ── -->
    <Color x:Key="ToolbarBgColor">#F8F9FA</Color>
    <Color x:Key="ToolbarHoverColor">#E8ECEF</Color>

    <SolidColorBrush x:Key="ToolbarBgBrush" Color="{StaticResource ToolbarBgColor}" />
    <SolidColorBrush x:Key="ToolbarHoverBrush" Color="{StaticResource ToolbarHoverColor}" />

    <!-- ── 侧栏深色主题 → 深海军蓝 ── -->
    <Color x:Key="SidebarBgColor">#1A1A2E</Color>
    <Color x:Key="SidebarHeaderBgColor">#151528</Color>
    <Color x:Key="SidebarTextColor">#B2BEC3</Color>
    <Color x:Key="SidebarHoverColor">#2D2D44</Color>
    <Color x:Key="SidebarAvatarColor">#3A3A55</Color>
    <Color x:Key="SidebarActiveColor">#81C784</Color>

    <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarBgColor}" />
    <SolidColorBrush x:Key="SidebarHeaderBgBrush" Color="{StaticResource SidebarHeaderBgColor}" />
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{StaticResource SidebarTextColor}" />
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}" />
    <SolidColorBrush x:Key="SidebarAvatarBrush" Color="{StaticResource SidebarAvatarColor}" />
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}" />

    <!-- ── 卡片渐变色 ── -->
    <Color x:Key="CardGreenStartColor">#E8F5E9</Color>
    <Color x:Key="CardGreenEndColor">#C8E6C9</Color>
    <Color x:Key="CardBlueStartColor">#E3F2FD</Color>
    <Color x:Key="CardBlueEndColor">#BBDEFB</Color>
    <Color x:Key="CardOrangeStartColor">#FFF3E0</Color>
    <Color x:Key="CardOrangeEndColor">#FFE0B2</Color>

    <!-- ── 阴影 ── -->
    <Color x:Key="ShadowColor">#33000000</Color>
    <Color x:Key="ShadowSmColor">#08000000</Color>
    <Color x:Key="ShadowMdColor">#0D000000</Color>

    <!-- ════════════════════════════════════════════════════════
         二、字体排版
         ═════════════════════════════════════════════════════════ -->

    <FontFamily x:Key="PrimaryFont">Microsoft YaHei UI, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="MonoFont">Consolas, Courier New, monospace</FontFamily>

    <sys:Double x:Key="FontSizeXs">10</sys:Double>
    <sys:Double x:Key="FontSizeSm">12</sys:Double>
    <sys:Double x:Key="FontSizeMd">14</sys:Double>
    <sys:Double x:Key="FontSizeLg">16</sys:Double>
    <sys:Double x:Key="FontSizeXl">20</sys:Double>
    <sys:Double x:Key="FontSizeXxl">24</sys:Double>

    <sys:Double x:Key="FontSizeToolbar">12</sys:Double>
    <sys:Double x:Key="FontSizeMenuItem">13</sys:Double>
    <sys:Double x:Key="FontSizeCaption">11</sys:Double>

    <!-- ════════════════════════════════════════════════════════
         三、间距与圆角
         ═════════════════════════════════════════════════════════ -->

    <sys:Double x:Key="SpacingSm">8</sys:Double>
    <sys:Double x:Key="SpacingMd">12</sys:Double>
    <sys:Double x:Key="SpacingLg">16</sys:Double>
    <sys:Double x:Key="SpacingXl">20</sys:Double>
    <sys:Double x:Key="SpacingXxl">24</sys:Double>
    <sys:Double x:Key="SpacingHuge">32</sys:Double>

    <CornerRadius x:Key="RadiusSm">8</CornerRadius>
    <CornerRadius x:Key="RadiusMd">12</CornerRadius>
    <CornerRadius x:Key="RadiusLg">16</CornerRadius>
    <CornerRadius x:Key="RadiusXl">20</CornerRadius>

    <sys:Double x:Key="TitlebarHeight">32</sys:Double>
    <sys:Double x:Key="ToolbarHeight">40</sys:Double>
    <sys:Double x:Key="MenuItemHeight">36</sys:Double>
    <sys:Double x:Key="InputHeight">38</sys:Double>
    <sys:Double x:Key="StatusBarHeight">32</sys:Double>

    <sys:Double x:Key="PopupMinWidth">180</sys:Double>
    <sys:Double x:Key="PopupNarrowWidth">150</sys:Double>

    <!-- ════════════════════════════════════════════════════════
         四、组件样式
         ═════════════════════════════════════════════════════════ -->

    <!-- 4.1 页面标题 -->
    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeXl}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <!-- 4.2 页面副标题 -->
    <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- 4.3 占位/提示文案 -->
    <Style x:Key="PlaceholderTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
    </Style>

    <!-- 4.4 工具栏 ToggleButton -->
    <Style x:Key="ToolbarButtonStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeToolbar}" />
        <Setter Property="Padding" Value="12,5" />
        <Setter Property="Margin" Value="2,3" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusSm}">
                        <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                            <TextBlock Text=" ▾"
                                       FontSize="{StaticResource FontSizeXs}"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       Margin="3,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ToolbarHoverBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{StaticResource BrandLightBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrandPrimaryBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 4.5 竖向导航按钮 -->
    <Style x:Key="NavButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMenuItem}" />
        <Setter Property="Height" Value="48" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="20,0,0,0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SidebarHoverBrush}" />
            </Trigger>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}" />
                <Setter Property="Foreground" Value="{StaticResource BrandDarkBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- 4.6 下拉菜单项 -->
    <Style x:Key="PopupMenuItemStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMenuItem}" />
        <Setter Property="Height" Value="{StaticResource MenuItemHeight}" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrandLightBrush}" />
                <Setter Property="Foreground" Value="#2E7D32" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 4.7 菜单分隔线 -->
    <Style x:Key="MenuSeparatorStyle" TargetType="Separator">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{StaticResource BorderBrush}" />
        <Setter Property="Margin" Value="10,3" />
    </Style>

    <!-- 4.8 下拉面板容器 -->
    <Style x:Key="PopupPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
    </Style>

    <!-- 4.9 文本框 -->
    <Style x:Key="StandardTextBoxStyle" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
        <Setter Property="Height" Value="{StaticResource InputHeight}" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource BgSecondaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- 4.10 密码框 -->
    <Style x:Key="StandardPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
        <Setter Property="Height" Value="{StaticResource InputHeight}" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource BgSecondaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- 4.11 主按钮（深色填充） -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="24,0" />
        <Setter Property="Background" Value="{StaticResource BrandDarkBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextInverseBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrandDarkBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusSm}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#2D2D44" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 4.12 次按钮（绿色填充） -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="24,0" />
        <Setter Property="Background" Value="{StaticResource BrandLightBrush}" />
        <Setter Property="Foreground" Value="#2E7D32" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            CornerRadius="{StaticResource RadiusSm}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#C8E6C9" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 4.13 边框按钮 -->
    <Style x:Key="OutlineButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="24,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusSm}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BgPrimaryBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 4.14 幽灵按钮（文本链接） -->
    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <TextBlock Text="{TemplateBinding Content}"
                               Foreground="{TemplateBinding Foreground}"
                               Cursor="Hand" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 4.15 状态栏文本 -->
    <Style x:Key="StatusBarTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
        <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
    </Style>

    <!-- 4.16 用户头像占位圆 -->
    <Style x:Key="AvatarPlaceholderStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Fill" Value="{StaticResource SidebarAvatarBrush}" />
    </Style>

    <!-- 4.17 深色卡片占位 -->
    <Style x:Key="DarkCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrandDarkBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <!-- ════════════════════════════════════════════════════════
         五、窗口容器 · 标题栏 · 按钮（主/子窗口共用）
         ═════════════════════════════════════════════════════════ -->

    <!-- 5.1 窗口主容器：白色背景 · 1px浅灰边框 · 6px圆角 -->
    <Style x:Key="WindowContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#c9c9c9" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- 5.2 窗口柔和阴影（已弃用，主窗口不再使用阴影） -->
    <Style x:Key="WindowShadowStyle" TargetType="Border">
        <Setter Property="Background" Value="#1A000000" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Margin" Value="0,3,0,-3" />
        <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
    </Style>

    <!-- 5.3 标题栏背景（顶部圆角，底部带分割线，统一高度32px，内高24px精确容纳24x24按钮垂直居中） -->
    <Style x:Key="TitlebarStyle" TargetType="Border">
        <Setter Property="Height" Value="{StaticResource TitlebarHeight}" />
        <Setter Property="Background" Value="#f2f2f2" />
        <Setter Property="CornerRadius" Value="6,6,0,0" />
        <Setter Property="BorderBrush" Value="#dddddd" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- 5.4 内容区背景色（浅灰） -->
    <SolidColorBrush x:Key="ContentAreaBrush" Color="#f5f5f5" />

    <!-- 5.4b 统一页面容器（共用布局框架：圆角6px + 标题栏 + 内容区） -->
    <Style x:Key="PageContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#c9c9c9" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- 5.4c 统一页面标题栏（浅灰底色 + 底部分割线，统一高度32px，内高24px精确容纳24x24按钮垂直居中） -->
    <Style x:Key="PageTitlebarStyle" TargetType="Border">
        <Setter Property="Height" Value="{StaticResource TitlebarHeight}" />
        <Setter Property="Background" Value="#f2f2f2" />
        <Setter Property="CornerRadius" Value="6,6,0,0" />
        <Setter Property="BorderBrush" Value="#dddddd" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- 5.4d 统一页面内容区（浅灰背景 + 底部圆角裁剪） -->
    <Style x:Key="PageContentStyle" TargetType="Border">
        <Setter Property="Background" Value="#f5f5f5" />
        <Setter Property="CornerRadius" Value="0,0,6,6" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- 5.5 标题栏通用按钮（24x24 · 透明底 · 3px圆角 · hover浅灰 · 与左侧16x16图标同视觉量级） -->
    <Style x:Key="TitleBtn" TargetType="Button">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Margin" Value="2,0" />
        <Setter Property="Foreground" Value="#333333" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="3"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#e8e8e8" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 5.6 标题栏关闭按钮（24x24 · hover红色 · 文字变白） -->
    <Style x:Key="CloseBtn" TargetType="Button">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Margin" Value="2,0" />
        <Setter Property="Foreground" Value="#333333" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="3"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#e81123" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 5.7 标题栏主要文字 -->
    <Style x:Key="TitlebarTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="#333333" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- 5.8 标题栏版本号文字 -->
    <Style x:Key="TitlebarVersionStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="#999999" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- 5.9 弹窗外层容器（统一6px圆角，与主窗口一致） -->
    <Style x:Key="ModalContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#c9c9c9" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- 5.10 弹窗标题栏（顶部圆角，底部直边 + 底部分隔线，10,4内边距精确容纳24x24按钮） -->
    <Style x:Key="ModalTitlebarStyle" TargetType="Border">
        <Setter Property="Background" Value="#f2f2f2" />
        <Setter Property="CornerRadius" Value="6,6,0,0" />
        <Setter Property="BorderBrush" Value="#dddddd" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- 5.11 弹窗底部内容区（底部圆角6px，统一主窗口规范） -->
    <Style x:Key="ModalContentStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ContentAreaBrush}" />
        <Setter Property="CornerRadius" Value="0,0,6,6" />
    </Style>

</ResourceDictionary>
